# Copy this file to .env and fill in real values. .env is gitignored.

# Mongo connection string (include username/password here if your DB requires auth)
MONGODB_URI=mongodb://127.0.0.1:27017/sales_crm

# Port the API listens on
PORT=4000

# 32+ byte random secret used to derive the AES-256 key for encrypting
# form response answers at rest. Generate one with: openssl rand -hex 32
# Required in production — the server refuses to start without it when
# NODE_ENV=production.
FORM_ENCRYPTION_KEY=

# Secret used to sign login session JWTs. Generate one with:
# openssl rand -hex 32
# Required in production — the server refuses to start without it when
# NODE_ENV=production. Rotating this invalidates every existing session.
JWT_SECRET=

# Set to "false" to disable the no-password demo-login endpoint
# (POST /api/auth/demo-login). Leave unset/true for local dev and demo
# deployments; set to "false" once this is a real production instance
# with real user accounts.
ALLOW_DEMO_LOGIN=

# Passwords for the three seeded demo login accounts (admin@pipeline.com,
# manager@pipeline.com, viewer@pipeline.com). Leave unset to keep the
# well-known local-dev defaults (admin123 / manager123 / viewer123).
DEMO_ADMIN_PASSWORD=
DEMO_MANAGER_PASSWORD=
DEMO_VIEWER_PASSWORD=

# --- WhatsApp Cloud API (Meta) ---
# Leave all three unset to run WhatsApp surveys in mock mode: messages are
# logged and stored locally instead of sent, and you can test full survey
# conversations via POST /api/whatsapp-surveys/simulate-reply with no real
# WhatsApp account needed.
#
# To go live: create a Meta developer app > WhatsApp product, grab a
# permanent access token + phone number ID, and set a webhook verify token
# of your choosing (also entered in the Meta dashboard when you register
# the webhook URL https://<your-domain>/api/whatsapp-surveys/webhook).
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
# App secret from the same Meta app (Settings > Basic) — used to verify
# the X-Hub-Signature-256 header Meta sends on every webhook POST, so a
# forged request to your public webhook URL gets rejected. Without this
# set, signature verification is skipped (a warning is logged once).
WHATSAPP_APP_SECRET=

# --- Transactional email (password reset, etc.) ---
# Leave all three unset to run in mock mode: emails are logged to the
# console instead of sent, and (non-production only) the reset link is
# also returned directly in the /forgot-password response so you can test
# the full flow with no real mail account.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Base URL of the frontend — used to build the password-reset link. Set to
# your real domain in production.
FRONTEND_URL=http://localhost:3000
